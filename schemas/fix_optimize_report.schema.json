{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/fix_optimize_report.schema.json",
  "title": "Codex FixOptimizeReport v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "schema_version",
    "task_id",
    "status",
    "blocking_findings_resolved",
    "optimization_rationale",
    "changed_files",
    "retest_reports",
    "regression_detected",
    "referenced_files",
    "timestamp"
  ],
  "properties": {
    "schema_ref": {
      "const": "workflows.md#FixOptimizeReport"
    },
    "schema_version": {
      "const": "v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{3}[A-Z]?$"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "blocking_findings_resolved": {
      "type": "boolean"
    },
    "optimization_rationale": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retest_reports": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(reports/)?(tasks/TASK-[0-9]{3}[A-Z]?|stages)/(static|unit|contract|api|integration|replay|snapshot|e2e)\\.json$"
      }
    },
    "regression_detected": {
      "type": "boolean"
    },
    "referenced_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "blocking_findings_resolved": {
            "const": true
          },
          "retest_reports": {
            "minItems": 1
          },
          "regression_detected": {
            "const": false
          }
        }
      }
    }
  ]
}
