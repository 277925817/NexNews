{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/task_acceptance_coverage.schema.json",
  "title": "Task Acceptance Coverage Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "schema_version",
    "status",
    "source",
    "coverage_items",
    "uncovered_task_acceptance_items",
    "timestamp"
  ],
  "properties": {
    "schema_ref": {
      "const": "07_test_spec.md#6.4"
    },
    "schema_version": {
      "const": "v1"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "const": "tasks.md"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "coverage_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "task_id",
          "source_path",
          "source_line",
          "acceptance_text",
          "acceptance_gate",
          "test_scope",
          "assertion_ids",
          "report_paths",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "pattern": "^TASK-[0-9]{3}[A-Z]?$"
          },
          "source_path": {
            "const": "tasks.md"
          },
          "source_line": {
            "type": "integer",
            "minimum": 1
          },
          "acceptance_text": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_gate": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^ACC-STOP-00[1-9]$|^ACC-STOP-010$|^none$"
            }
          },
          "test_scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "static",
                "unit",
                "contract",
                "api",
                "integration",
                "replay",
                "snapshot",
                "e2e"
              ]
            }
          },
          "assertion_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "report_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "uncovered"
            ]
          }
        }
      }
    },
    "uncovered_task_acceptance_items": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object"
          }
        ]
      }
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    }
  }
}
