{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/task_plan_report.schema.json",
  "title": "Codex TaskPlanReport v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "schema_version",
    "task_id",
    "prd_source",
    "unimplemented_prd_items",
    "selected_related_features",
    "prd_items",
    "scope",
    "deliverable_submodule",
    "round_acceptance_criteria",
    "files",
    "test_stages",
    "test_commands",
    "rollback_boundary",
    "acceptance_gate_impact",
    "timestamp"
  ],
  "properties": {
    "schema_ref": {
      "const": "workflows.md#TaskPlanReport"
    },
    "schema_version": {
      "const": "v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{3}[A-Z]?$"
    },
    "prd_source": {
      "const": "docs/01_prd.md"
    },
    "unimplemented_prd_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "selected_related_features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prd_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "deliverable_submodule": {
      "type": "string",
      "minLength": 1
    },
    "round_acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "test_stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "static",
          "unit",
          "contract",
          "api",
          "integration",
          "replay",
          "snapshot",
          "e2e"
        ]
      }
    },
    "test_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_boundary": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_gate_impact": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ACC-STOP-00[1-9]$|^ACC-STOP-010$"
      }
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    }
  }
}
