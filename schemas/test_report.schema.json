{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/test_report.schema.json",
  "title": "Codex Harness TestReport v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "schema_version",
    "test_id",
    "stage",
    "status",
    "failure_type",
    "error_category",
    "trace_id",
    "fixture_set",
    "mock_set",
    "clock_source",
    "fixture_version",
    "mock_version",
    "commands",
    "case_count",
    "passed_count",
    "failed_count",
    "skipped_count",
    "pass_rate",
    "failure_reasons",
    "repair_status",
    "regression_detected",
    "referenced_files",
    "data_hash",
    "artifact_paths",
    "assertions",
    "expected",
    "actual",
    "diff",
    "node",
    "timestamp"
  ],
  "properties": {
    "schema_ref": {
      "const": "07_test_spec.md#6"
    },
    "schema_version": {
      "const": "v2"
    },
    "test_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "enum": [
        "static",
        "unit",
        "contract",
        "api",
        "integration",
        "replay",
        "snapshot",
        "e2e",
        "acceptance"
      ]
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "flaky",
        "skipped"
      ]
    },
    "failure_type": {
      "enum": [
        "api",
        "scheduler",
        "integration",
        "contract",
        "data_model",
        "ui",
        "observability",
        "leak",
        null
      ]
    },
    "error_category": {
      "enum": [
        "network",
        "parsing",
        "llm",
        "validation_llm_error",
        "database",
        "validation",
        "timeout",
        "unknown",
        null
      ]
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "fixture_set": {
      "type": "string",
      "minLength": 1
    },
    "mock_set": {
      "type": "string",
      "minLength": 1
    },
    "clock_source": {
      "type": "string",
      "minLength": 1
    },
    "fixture_version": {
      "type": "string",
      "minLength": 1
    },
    "mock_version": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "case_count": {
      "type": "integer",
      "minimum": 0
    },
    "passed_count": {
      "type": "integer",
      "minimum": 0
    },
    "failed_count": {
      "type": "integer",
      "minimum": 0
    },
    "skipped_count": {
      "type": "integer",
      "minimum": 0
    },
    "pass_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "failure_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repair_status": {
      "enum": [
        "not_required",
        "unresolved",
        "fixed",
        "blocked"
      ]
    },
    "regression_detected": {
      "type": "boolean"
    },
    "referenced_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "data_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "artifact_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/assertion"
      }
    },
    "expected": {
      "type": "object"
    },
    "actual": {
      "type": "object"
    },
    "diff": {
      "type": "object"
    },
    "node": {
      "enum": [
        "harness",
        "acceptance",
        "static",
        "source",
        "RSS",
        "scheduler",
        "score",
        "filter",
        "fetch",
        "translate",
        "DB",
        "API",
        "UI"
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "visibility",
        "status",
        "expected",
        "actual",
        "diff",
        "leak_detection"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(A-(static|unit|contract|api|integration|replay|snapshot|e2e|acceptance)-ACC-STOP-(00[1-9]|010)-[a-z0-9]+(-[a-z0-9]+)*|[a-z0-9][a-z0-9_-]*)$"
        },
        "type": {
          "enum": [
            "api_response",
            "db_state",
            "side_effect",
            "pipeline_output",
            "llm_io",
            "ui_render",
            "report_schema",
            "log_record",
            "isolation"
          ]
        },
        "visibility": {
          "enum": [
            "public_surface",
            "internal_evidence",
            "report_metadata"
          ]
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "flaky",
            "skipped"
          ]
        },
        "expected": {
          "type": "object"
        },
        "actual": {
          "type": "object"
        },
        "diff": {
          "type": "object"
        },
        "leak_detection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "target",
            "forbidden_field_count",
            "sensitive_content_count",
            "matched_paths"
          ],
          "properties": {
            "method": {
              "const": "structured_field_scan"
            },
            "target": {
              "enum": [
                "api_json",
                "ui_dom",
                "logs",
                "test_report",
                null
              ]
            },
            "forbidden_field_count": {
              "type": "integer",
              "minimum": 0
            },
            "sensitive_content_count": {
              "type": "integer",
              "minimum": 0
            },
            "matched_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
